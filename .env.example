# ── Supabase ──────────────────────────────────────────────────────────────
# Project settings → API. Required for auth + database.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Project settings → API → "service_role" secret key. Server-only, never
# exposed to the browser. Required for the Stripe webhook to update a
# user's plan without a logged-in session.
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (AI coach) ────────────────────────────────────────────────────
# Optional. Without it, /api/analyze uses the built-in heuristic coaching
# engine (services/ai/heuristic-provider.ts) — real scores and feedback
# computed from the transcript, no external API required. Set this to have
# gpt-4o-mini write the narrative feedback instead.
OPENAI_API_KEY=

# ── Stripe (billing) ─────────────────────────────────────────────────────
# Developers → API keys. Required for the "Upgrade to Pro" checkout flow.
STRIPE_SECRET_KEY=
# Developers → Webhooks → your endpoint → "Signing secret".
STRIPE_WEBHOOK_SECRET=
# Product catalog → the recurring Price id for the Pro plan (starts with "price_").
STRIPE_PRICE_ID_PRO=
